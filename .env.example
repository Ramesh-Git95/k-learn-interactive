// Development Environment Configuration
// Copy this file to .env.local to configure your development environment

// API Backend URL (for authentication and user data)
VITE_API_URL=http://localhost:5000/api

// Gemini AI Configuration (Optional)
// Get your API key from: https://ai.google.dev/
// VITE_GEMINI_API_KEY=your_api_key_here

// Application Configuration
NODE_ENV=development
VITE_NODE_ENV=development

// Enable debug mode for development
VITE_DEBUG=true

// Tips:
// - The app works perfectly without the Gemini API key
// - AI features (vocabulary examples, conversation bot, translation) will be disabled
// - All core learning features remain fully functional
// - Set GEMINI_API_KEY to enable AI-powered features
